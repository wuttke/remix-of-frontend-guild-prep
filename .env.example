# Pocket Dev Guild Frontend Configuration
#
# DEFAULT BEHAVIOR (no env file present, e.g. in Lovable preview):
#   → Mock data is used. No backend required.
#
# LOCAL DEVELOPMENT against your real backend:
#   1. Copy this file to `.env.local` (gitignored, never shipped to Lovable):
#        cp .env.example .env.local
#   2. Set VITE_USE_MOCK_DATA=false there.
#   3. Start backend on http://localhost:8000.
#   Vite proxies /api → http://localhost:8000 (see vite.config.ts).
#
# Only "false" disables mock mode. Any other value (or unset) keeps mock on.
VITE_USE_MOCK_DATA=false
